# Canonical shared Firebase config for Agent Manager (client-side keys, not
# secrets). This file is the single source of truth when rotating the shared
# Firebase project.
#
# Four scripts embed fallback copies of these values (they must stay standalone
# — setup.sh is scp'd alone to a VPS, migrate-to-expo.sh is curl'd alone onto
# boxes). When you change a value here, update all of:
#   - setup.sh          (EXPO_PUBLIC_* heredoc)
#   - ubuntu-install.sh (EXPO_PUBLIC_* heredoc)
#   - mac-install.sh    (EXPO_PUBLIC_* heredoc)
#   - migrate-to-expo.sh (FB_* defaults; sources this file when present)
EXPO_PUBLIC_FIREBASE_API_KEY=AIzaSyCGCFvt5iN93rQkH6R5zStANc2ZGj_YL8E
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=claude-manager-chat.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=claude-manager-chat
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=claude-manager-chat.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1041886556076
EXPO_PUBLIC_FIREBASE_APP_ID=1:1041886556076:web:22e67ff4818b56c80e9409
